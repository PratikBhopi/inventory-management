@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="page-container">
<div class="error-container">
    <div class="error-icon">
        <i class="fas fa-exclamation-triangle"></i>
    </div>
    
    <h1>Oops! Something Went Wrong</h1>
    <p class="error-message">We encountered an unexpected error while processing your request.</p>
    
    @if (Model.ShowRequestId)
    {
        <div class="error-details">
            <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
            <p class="text-muted">Please provide this ID when contacting support.</p>
        </div>
    }
    
    <div class="error-actions">
        <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg">
            <i class="fas fa-home"></i> Go to Home
        </a>
        <button onclick="history.back()" class="btn btn-secondary btn-lg">
            <i class="fas fa-arrow-left"></i> Go Back
        </button>
    </div>
    
    @if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
    {
        <div class="dev-notice">
            <h3><i class="fas fa-code"></i> Development Mode</h3>
            <p>You're seeing this because the application is running in <strong>Development</strong> mode.</p>
            <p class="text-warning">
                <i class="fas fa-exclamation-circle"></i>
                <strong>Warning:</strong> Development mode should not be enabled for deployed applications as it may display sensitive information.
            </p>
        </div>
    }
</div>
</div>

<style>
    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 var(--space-md);
    }
    
    .error-container {
        max-width: 700px;
        margin: var(--space-xl) auto;
        text-align: center;
        padding: var(--space-xl);
    }
    
    .error-icon {
        width: 120px;
        height: 120px;
        margin: 0 auto var(--space-lg);
        background: linear-gradient(135deg, var(--accent-red), #dc2626);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        color: var(--pure-white);
        animation: pulse 2s ease-in-out infinite;
    }
    
    @@keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
    }
    
    .error-container h1 {
        font-size: 2.5rem;
        color: var(--sepia-dark);
        margin-bottom: var(--space-md);
    }
    
    .error-message {
        font-size: 1.125rem;
        color: var(--medium-grey);
        margin-bottom: var(--space-xl);
    }
    
    .error-details {
        background: var(--off-white);
        padding: var(--space-lg);
        border-radius: var(--radius-md);
        border: 2px solid var(--light-grey);
        margin-bottom: var(--space-xl);
    }
    
    .error-details code {
        background: var(--pure-white);
        padding: 0.25rem 0.5rem;
        border-radius: var(--radius-sm);
        font-family: var(--font-body);
        color: var(--accent-red);
        border: 1px solid var(--light-grey);
    }
    
    .error-actions {
        display: flex;
        gap: var(--space-md);
        justify-content: center;
        margin-bottom: var(--space-xl);
    }
    
    .dev-notice {
        background: var(--primary-yellow);
        padding: var(--space-lg);
        border-radius: var(--radius-md);
        border: 2px solid var(--sepia-medium);
        margin-top: var(--space-xl);
        text-align: left;
    }
    
    .dev-notice h3 {
        color: var(--sepia-dark);
        margin-bottom: var(--space-md);
        font-size: 1.25rem;
    }
    
    .dev-notice p {
        color: var(--sepia-dark);
        margin-bottom: var(--space-sm);
    }
    
    .text-warning {
        color: var(--sepia-dark) !important;
        font-weight: 600;
        background: rgba(239, 68, 68, 0.1);
        padding: var(--space-sm);
        border-radius: var(--radius-sm);
    }
    
    .text-warning i {
        color: var(--accent-red);
    }
    
    @@media (max-width: 768px) {
        .error-actions {
            flex-direction: column;
        }
        
        .error-actions .btn {
            width: 100%;
        }
    }
</style>
