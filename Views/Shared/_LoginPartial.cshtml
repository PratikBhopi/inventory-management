@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav retro-auth-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="retro-nav-link" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            <i class="fas fa-user-circle"></i>
            <span>@User.Identity?.Name</span>
        </a>
    </li>
    <li class="nav-item">
        <form class="nav-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="retro-nav-link retro-nav-button">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="retro-nav-link" asp-area="Identity" asp-page="/Account/Register">
            <i class="fas fa-user-plus"></i>
            <span>Register</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="retro-nav-link" asp-area="Identity" asp-page="/Account/Login">
            <i class="fas fa-sign-in-alt"></i>
            <span>Login</span>
        </a>
    </li>
}
</ul>
