@model ShopBillingSystem.ViewModels.OrderViewModel

@{
    ViewData["Title"] = "Receipt";
}

<div class="page-container">
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header text-center bg-primary text-white">
                    <h3><i class="fas fa-receipt"></i> Sales Receipt</h3>
                </div>
                <div class="card-body" id="receiptContent">
                    <div class="text-center mb-4">
                        <h4>Shop Billing System</h4>
                        <p class="mb-1">123 Main Street, City, State 12345</p>
                        <p class="mb-1">Phone: (555) 123-4567</p>
                        <hr>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <strong>Receipt #:</strong> @Model.Id<br>
                            <strong>Date:</strong> @Model.OrderDate.ToString("MM/dd/yyyy hh:mm tt")
                        </div>
                        <div class="col-6 text-end">
                            <strong>Customer:</strong> @Model.CustomerName<br>
                            <strong>Cashier:</strong> @(Model.UserId ?? "System")
                        </div>
                    </div>

                    <hr>

                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Price</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">$@item.UnitPrice.ToString("F2")</td>
                                    <td class="text-end">$@item.Subtotal.ToString("F2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <hr>

                    <div class="row">
                        <div class="col-6">
                            <p><strong>Items Count:</strong> @Model.ItemsCount</p>
                        </div>
                        <div class="col-6 text-end">
                            <h4><strong>Total Amount: $@Model.TotalAmount.ToString("F2")</strong></h4>
                        </div>
                    </div>

                    <hr>

                    <div class="text-center">
                        <p class="mb-1">Thank you for your business!</p>
                        <p class="mb-1">Please come again</p>
                        <small class="text-muted">Generated on @DateTime.Now.ToString("MM/dd/yyyy hh:mm tt")</small>
                    </div>
                </div>
                
                <div class="card-footer text-center">
                    <button type="button" class="btn btn-primary me-2" onclick="window.print()">
                        <i class="fas fa-print"></i> Print Receipt
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-success me-2">
                        <i class="fas fa-plus"></i> New Sale
                    </a>
                    <a href="@Url.Action("Orders")" class="btn btn-secondary">
                        <i class="fas fa-list"></i> View All Orders
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

@section Styles {
    <style>
        .page-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 var(--space-md);
        }
        
        .card {
            box-shadow: var(--shadow-md);
        }
        
        @@media print {
            /* Hide all UI elements */
            .card-header, 
            .card-footer, 
            .btn,
            button,
            a.btn {
                display: none !important;
            }
            
            /* Remove card styling */
            .card {
                border: none !important;
                box-shadow: none !important;
                margin: 0 !important;
            }
            
            .card-body {
                padding: 0 !important;
            }
            
            /* Clean print layout */
            body {
                font-size: 11pt !important;
                background: white !important;
            }
            
            .page-container,
            .container,
            .row,
            .col-md-8 {
                max-width: 100% !important;
                padding: 0 !important;
                margin: 0 !important;
            }
            
            /* Table styling for print */
            .table {
                font-size: 10pt;
                border-collapse: collapse !important;
                border-radius: 0 !important;
                overflow: visible !important;
                border: none !important;
            }
            
            .table th,
            .table td {
                padding: 6px !important;
                border: 1px solid #333 !important;
                color: #000 !important;
                border-radius: 0 !important;
            }
            
            .table thead {
                border-radius: 0 !important;
            }
            
            .table thead th {
                background-color: #d0d0d0 !important;
                color: #000 !important;
                font-weight: bold !important;
                border-radius: 0 !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
                color-adjust: exact !important;
            }
            
            .table thead th:first-child {
                border-top-left-radius: 0 !important;
            }
            
            .table thead th:last-child {
                border-top-right-radius: 0 !important;
            }
            
            .table tbody {
                border-radius: 0 !important;
            }
            
            .table tbody td {
                background-color: #fff !important;
                border-radius: 0 !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
            
            .table tbody tr:last-child td {
                border-radius: 0 !important;
            }
            
            .table tbody tr:last-child td:first-child {
                border-bottom-left-radius: 0 !important;
            }
            
            .table tbody tr:last-child td:last-child {
                border-bottom-right-radius: 0 !important;
            }
            
            .table-responsive {
                border-radius: 0 !important;
                overflow: visible !important;
            }
            
            /* Ensure proper spacing */
            hr {
                border-top: 1px solid #000 !important;
                margin: 0.5rem 0 !important;
            }
            
            h3, h4 {
                margin: 0.5rem 0 !important;
            }
            
            p {
                margin: 0.25rem 0 !important;
            }
        }
    </style>
}