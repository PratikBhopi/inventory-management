@model ShopBillingSystem.ViewModels.OrderListViewModel

@{
    ViewData["Title"] = "Orders History";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-history"></i> Orders History</h2>
        <a href="@Url.Action("Index")" class="btn btn-primary">
            <i class="fas fa-plus"></i> New Sale
        </a>
    </div>

    @if (!Model.Orders.Any())
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle"></i> No orders found. <a href="@Url.Action("Index")">Create your first sale</a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Order #</th>
                                <th>Customer Name</th>
                                <th>Order Date</th>
                                <th>Items Count</th>
                                <th>Total Amount</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.Orders)
                            {
                                <tr>
                                    <td>
                                        <strong>#@order.Id</strong>
                                    </td>
                                    <td>@order.CustomerName</td>
                                    <td>@order.OrderDate.ToString("MM/dd/yyyy hh:mm tt")</td>
                                    <td>
                                        <span class="badge bg-info">@order.ItemsCount items</span>
                                    </td>
                                    <td>
                                        <strong class="text-success">$@order.TotalAmount.ToString("F2")</strong>
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Receipt", new { id = order.Id })" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-receipt"></i> View Receipt
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <div class="row">
                <div class="col-md-3">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title">Total Orders</h5>
                            <h3 class="text-primary">@Model.TotalOrders</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title">Total Revenue</h5>
                            <h3 class="text-success">$@Model.TotalRevenue.ToString("F2")</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title">Items Sold</h5>
                            <h3 class="text-info">@Model.TotalItemsSold</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title">Avg Order Value</h5>
                            <h3 class="text-warning">$@Model.AverageOrderValue.ToString("F2")</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Styles {
    <style>
        .card {
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        }
        
        .table-hover tbody tr:hover {
            background-color: rgba(0, 0, 0, 0.025);
        }
        
        .text-success {
            color: #198754 !important;
        }
        
        .text-primary {
            color: #0d6efd !important;
        }
        
        .text-info {
            color: #0dcaf0 !important;
        }
        
        .text-warning {
            color: #ffc107 !important;
        }
    </style>
}