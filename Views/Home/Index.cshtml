@{
    ViewData["Title"] = "Home";
}

<div class="retro-hero full-width-section">
    <div class="hero-content-wrapper">
        <div class="hero-content">
            <h1 class="hero-title">
                <span class="title-line-1">Welcome to</span>
                <span class="title-line-2">ShopBilling</span>
            </h1>
            <p class="hero-tagline">Your Groovy Point-of-Sale System</p>
            <p class="hero-subtitle">Retro vibes, modern features – manage your shop like it's 1959!</p>
            
            <div class="hero-actions">
                <a asp-controller="Billing" asp-action="Index" class="btn btn-hero-primary">
                    <i class="fas fa-cash-register"></i> Start Ringing Up Sales
                </a>
                <a asp-controller="Products" asp-action="Index" class="btn btn-hero-secondary">
                    <i class="fas fa-box"></i> Stock Your Shelves
                </a>
            </div>
        </div>
        
        <div class="hero-decoration">
            <div class="diner-sign">
                <div class="neon-text">OPEN</div>
                <div class="neon-subtext">24/7</div>
            </div>
        </div>
    </div>
</div>

<div class="features-section">
    <div class="section-header">
        <h2 class="section-title">What's Cookin'?</h2>
        <p class="section-subtitle">Everything you need to run your shop, served fresh daily</p>
    </div>
    
    <div class="features-grid">
        <div class="feature-card feature-coral">
            <div class="feature-icon-wrapper">
                <i class="fas fa-bolt feature-icon"></i>
            </div>
            <h3 class="feature-title">Lightning Fast Checkout</h3>
            <p class="feature-description">Ring up customers faster than a jukebox plays a hit record. Our POS is built for speed!</p>
            <div class="feature-badge">SPEEDY</div>
        </div>
        
        <div class="feature-card feature-teal">
            <div class="feature-icon-wrapper">
                <i class="fas fa-boxes feature-icon"></i>
            </div>
            <h3 class="feature-title">Inventory That Pops</h3>
            <p class="feature-description">Track your stock like a pro. Know what's hot and what's not with real-time inventory management.</p>
            <div class="feature-badge">ORGANIZED</div>
        </div>
        
        <div class="feature-card feature-yellow">
            <div class="feature-icon-wrapper">
                <i class="fas fa-chart-line feature-icon"></i>
            </div>
            <h3 class="feature-title">Sales That Sizzle</h3>
            <p class="feature-description">Watch your numbers climb! View order history and track your business performance in style.</p>
            <div class="feature-badge">GROOVY</div>
        </div>
        
        <div class="feature-card feature-coral">
            <div class="feature-icon-wrapper">
                <i class="fas fa-receipt feature-icon"></i>
            </div>
            <h3 class="feature-title">Receipts with Pizzazz</h3>
            <p class="feature-description">Generate professional receipts that look sharp. Every transaction gets the VIP treatment!</p>
            <div class="feature-badge">CLASSY</div>
        </div>
    </div>
</div>

<div class="cta-section full-width-section">
    <div class="cta-content">
        <h2 class="cta-title">Ready to Rock & Roll?</h2>
        <p class="cta-subtitle">Join the coolest shop owners in town and start managing your business the retro way!</p>
        <a asp-controller="Billing" asp-action="Index" class="btn btn-cta-large">
            <i class="fas fa-rocket"></i> Let's Get Started!
        </a>
    </div>
    <div class="cta-decoration">
        <div class="vinyl-record">
            <div class="vinyl-center"></div>
            <div class="vinyl-groove"></div>
        </div>
    </div>
</div>

<style>
    /* Hero Section - Retro Diner Style */
    .retro-hero {
        background: linear-gradient(135deg, var(--primary-coral) 0%, var(--primary-teal) 100%);
        padding: 4rem 2rem;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-xl);
    }
    
    .retro-hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: 
            repeating-linear-gradient(
                45deg,
                transparent,
                transparent 10px,
                rgba(255,255,255,0.03) 10px,
                rgba(255,255,255,0.03) 20px
            );
        pointer-events: none;
    }
    
    .hero-content-wrapper {
        max-width: 1400px;
        margin: 0 auto;
        position: relative;
        padding: 0 var(--space-md);
    }
    
    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
    }
    
    .hero-badge {
        display: inline-block;
        background: rgba(255,255,255,0.2);
        color: var(--pure-white);
        padding: 0.5rem 1.5rem;
        border-radius: 50px;
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 0.875rem;
        letter-spacing: 2px;
        margin-bottom: var(--space-md);
        border: 2px solid rgba(255,255,255,0.3);
    }
    
    .hero-title {
        margin-bottom: var(--space-md);
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    
    .title-line-1 {
        font-family: var(--font-serif);
        font-size: 1.5rem;
        color: var(--pure-white);
        font-weight: 400;
        font-style: italic;
        opacity: 0.95;
    }
    
    .title-line-2 {
        font-family: var(--font-display);
        font-size: 4rem;
        color: var(--pure-white);
        text-shadow: 
            4px 4px 0px rgba(0,0,0,0.2),
            -2px -2px 0px rgba(255,255,255,0.1);
        letter-spacing: 2px;
        line-height: 1;
    }
    
    .hero-tagline {
        font-family: var(--font-display);
        font-size: 1.75rem;
        color: var(--primary-yellow);
        margin-bottom: var(--space-sm);
        text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
    }
    
    .hero-subtitle {
        font-family: var(--font-body);
        font-size: 1.125rem;
        color: var(--pure-white);
        margin-bottom: var(--space-xl);
        opacity: 0.95;
    }
    
    .hero-actions {
        display: flex;
        gap: var(--space-md);
        justify-content: center;
        flex-wrap: wrap;
    }
    
    .btn-hero-primary {
        background: var(--pure-white);
        color: var(--primary-coral);
        border: 3px solid var(--pure-white);
        font-size: 1.125rem;
        padding: 1rem 2rem;
        font-weight: 700;
        box-shadow: 0 8px 16px rgba(0,0,0,0.2);
    }
    
    .btn-hero-primary:hover {
        background: var(--primary-yellow);
        color: var(--sepia-dark);
        border-color: var(--primary-yellow);
        transform: translateY(-4px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.3);
    }
    
    .btn-hero-secondary {
        background: transparent;
        color: var(--pure-white);
        border: 3px solid var(--pure-white);
        font-size: 1.125rem;
        padding: 1rem 2rem;
        font-weight: 700;
    }
    
    .btn-hero-secondary:hover {
        background: var(--pure-white);
        color: var(--primary-teal);
        transform: translateY(-4px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.3);
    }
    
    /* Diner Sign Decoration */
    .hero-decoration {
        position: absolute;
        top: 2rem;
        right: 2rem;
        z-index: 1;
    }
    
    .diner-sign {
        background: var(--sepia-dark);
        padding: 1.5rem 2rem;
        border-radius: var(--radius-md);
        border: 4px solid var(--primary-yellow);
        box-shadow: 
            0 0 20px rgba(255,230,109,0.5),
            inset 0 0 20px rgba(255,230,109,0.2);
        transform: rotate(-5deg);
    }
    
    .neon-text {
        font-family: var(--font-display);
        font-size: 2.5rem;
        color: var(--primary-yellow);
        text-shadow: 
            0 0 10px var(--primary-yellow),
            0 0 20px var(--primary-yellow),
            0 0 30px var(--primary-coral);
        line-height: 1;
    }
    
    .neon-subtext {
        font-family: var(--font-body);
        font-size: 1rem;
        color: var(--primary-teal);
        text-align: center;
        margin-top: 0.5rem;
        text-shadow: 0 0 10px var(--primary-teal);
    }
    
    /* Features Section */
    .features-section {
        margin: var(--space-xl) auto;
        max-width: 1400px;
        padding: 0 var(--space-md);
    }
    
    .section-header {
        text-align: center;
        margin-bottom: var(--space-xl);
    }
    
    .section-title {
        font-family: var(--font-display);
        font-size: 3rem;
        color: var(--primary-coral);
        margin-bottom: var(--space-sm);
        text-shadow: 2px 2px 0px var(--primary-yellow);
    }
    
    .section-subtitle {
        font-family: var(--font-serif);
        font-size: 1.25rem;
        color: var(--sepia-medium);
        font-style: italic;
    }
    
    .features-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-lg);
    }
    
    .feature-card {
        background: var(--pure-white);
        padding: var(--space-xl);
        border-radius: var(--radius-lg);
        border: 3px solid;
        position: relative;
        overflow: hidden;
        transition: all var(--transition-base);
        box-shadow: var(--shadow-md);
    }
    
    .feature-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 6px;
        background: currentColor;
    }
    
    .feature-coral {
        border-color: var(--primary-coral);
        color: var(--primary-coral);
    }
    
    .feature-teal {
        border-color: var(--primary-teal);
        color: var(--primary-teal);
    }
    
    .feature-yellow {
        border-color: var(--sepia-medium);
        color: var(--sepia-medium);
    }
    
    .feature-card:hover {
        transform: translateY(-8px) rotate(-1deg);
        box-shadow: var(--shadow-xl);
    }
    
    .feature-icon-wrapper {
        width: 80px;
        height: 80px;
        background: currentColor;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto var(--space-md);
        position: relative;
    }
    
    .feature-icon-wrapper::after {
        content: '';
        position: absolute;
        inset: -8px;
        border: 3px dashed currentColor;
        border-radius: 50%;
        opacity: 0.3;
    }
    
    .feature-icon {
        font-size: 2.5rem;
        color: var(--pure-white);
    }
    
    .feature-title {
        font-family: var(--font-display);
        font-size: 1.5rem;
        color: var(--sepia-dark);
        margin-bottom: var(--space-sm);
        text-align: center;
    }
    
    .feature-description {
        font-family: var(--font-body);
        font-size: 0.9375rem;
        color: var(--medium-grey);
        text-align: center;
        line-height: 1.6;
        margin-bottom: var(--space-md);
    }
    
    .feature-badge {
        display: inline-block;
        background: currentColor;
        color: var(--pure-white);
        padding: 0.375rem 1rem;
        border-radius: 50px;
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 0.75rem;
        letter-spacing: 1px;
        position: absolute;
        bottom: var(--space-md);
        left: 50%;
        transform: translateX(-50%);
    }
    
    /* CTA Section */
    .cta-section {
        background: linear-gradient(135deg, var(--sepia-dark) 0%, var(--sepia-medium) 100%);
        padding: 4rem 2rem;
        margin: var(--space-xl) 0 0 0;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-xl);
    }
    
    .cta-content {
        position: relative;
        z-index: 2;
        text-align: center;
        max-width: 700px;
        margin: 0 auto;
    }
    
    .cta-title {
        font-family: var(--font-display);
        font-size: 3rem;
        color: var(--primary-yellow);
        margin-bottom: var(--space-sm);
        text-shadow: 3px 3px 0px rgba(0,0,0,0.3);
    }
    
    .cta-subtitle {
        font-family: var(--font-serif);
        font-size: 1.25rem;
        color: var(--aged-paper);
        margin-bottom: var(--space-xl);
        font-style: italic;
    }
    
    .btn-cta-large {
        background: var(--primary-coral);
        color: var(--pure-white);
        border: 3px solid var(--primary-coral);
        font-size: 1.5rem;
        padding: 1.25rem 3rem;
        font-weight: 700;
        box-shadow: 0 8px 16px rgba(0,0,0,0.3);
    }
    
    .btn-cta-large:hover {
        background: var(--primary-teal);
        border-color: var(--primary-teal);
        transform: translateY(-4px) scale(1.05);
        box-shadow: 0 12px 24px rgba(0,0,0,0.4);
    }
    
    /* Vinyl Record Decoration */
    .cta-decoration {
        position: absolute;
        bottom: -50px;
        right: -50px;
        z-index: 1;
        opacity: 0.1;
    }
    
    .vinyl-record {
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, #1a1a1a 0%, #000 100%);
        border-radius: 50%;
        position: relative;
        animation: spin 20s linear infinite;
    }
    
    .vinyl-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 80px;
        height: 80px;
        background: var(--primary-coral);
        border-radius: 50%;
        border: 3px solid var(--primary-yellow);
    }
    
    .vinyl-groove {
        position: absolute;
        inset: 20px;
        border: 2px solid rgba(255,255,255,0.1);
        border-radius: 50%;
    }
    
    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    
    /* Responsive Design */
    @@media (max-width: 768px) {
        .title-line-2 {
            font-size: 2.5rem;
        }
        
        .hero-tagline {
            font-size: 1.25rem;
        }
        
        .hero-subtitle {
            font-size: 1rem;
        }
        
        .hero-decoration {
            display: none;
        }
        
        .section-title {
            font-size: 2rem;
        }
        
        .cta-title {
            font-size: 2rem;
        }
        
        .features-grid {
            grid-template-columns: 1fr;
        }
        
        .btn-cta-large {
            font-size: 1.25rem;
            padding: 1rem 2rem;
        }
    }
    
    @@media (min-width: 769px) and (max-width: 1024px) {
        .features-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>
