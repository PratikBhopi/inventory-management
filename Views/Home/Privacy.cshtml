@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="page-container">
<div class="page-header">
    <h1><i class="fas fa-shield-alt"></i> Privacy Policy</h1>
    <p class="text-muted">How we protect and handle your information</p>
</div>

<div class="privacy-container">
    <div class="card">
        <div class="card-header">
            <h3><i class="fas fa-lock"></i> Your Privacy Matters</h3>
        </div>
        <div class="card-body">
            <section class="privacy-section">
                <h4><i class="fas fa-info-circle"></i> Information We Collect</h4>
                <p>ShopBilling collects only the information necessary to provide our point-of-sale services:</p>
                <ul>
                    <li>Customer names for order processing</li>
                    <li>Product information for inventory management</li>
                    <li>Transaction records for business analytics</li>
                    <li>User account information for system access</li>
                </ul>
            </section>
            
            <section class="privacy-section">
                <h4><i class="fas fa-database"></i> How We Use Your Data</h4>
                <p>Your data is used exclusively for:</p>
                <ul>
                    <li>Processing sales transactions</li>
                    <li>Managing inventory and products</li>
                    <li>Generating receipts and reports</li>
                    <li>Improving our services</li>
                </ul>
            </section>
            
            <section class="privacy-section">
                <h4><i class="fas fa-shield-alt"></i> Data Security</h4>
                <p>We implement industry-standard security measures to protect your information:</p>
                <ul>
                    <li>Encrypted data transmission</li>
                    <li>Secure database storage</li>
                    <li>Regular security audits</li>
                    <li>Access control and authentication</li>
                </ul>
            </section>
            
            <section class="privacy-section">
                <h4><i class="fas fa-user-shield"></i> Your Rights</h4>
                <p>You have the right to:</p>
                <ul>
                    <li>Access your personal data</li>
                    <li>Request data corrections</li>
                    <li>Request data deletion</li>
                    <li>Opt-out of data collection</li>
                </ul>
            </section>
            
            <section class="privacy-section">
                <h4><i class="fas fa-envelope"></i> Contact Us</h4>
                <p>If you have questions about our privacy practices, please contact us at:</p>
                <p><strong>Email:</strong> privacy@shopbilling.com</p>
                <p><strong>Last Updated:</strong> April 2026</p>
            </section>
        </div>
    </div>
</div>
</div>

<style>
    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 var(--space-md);
    }
    
    .page-header {
        margin-bottom: var(--space-xl);
        padding-bottom: var(--space-lg);
        border-bottom: 3px solid var(--primary-coral);
    }
    
    .privacy-container {
        max-width: 900px;
        margin: 0 auto;
    }
    
    .privacy-section {
        margin-bottom: var(--space-xl);
        padding-bottom: var(--space-lg);
        border-bottom: 1px solid var(--light-grey);
    }
    
    .privacy-section:last-child {
        border-bottom: none;
    }
    
    .privacy-section h4 {
        font-size: 1.25rem;
        color: var(--sepia-dark);
        margin-bottom: var(--space-md);
        font-family: var(--font-display);
    }
    
    .privacy-section h4 i {
        color: var(--primary-teal);
        margin-right: 0.5rem;
    }
    
    .privacy-section p {
        color: var(--medium-grey);
        line-height: 1.8;
        margin-bottom: var(--space-sm);
    }
    
    .privacy-section ul {
        list-style: none;
        padding-left: 0;
    }
    
    .privacy-section ul li {
        padding: var(--space-xs) 0;
        padding-left: var(--space-lg);
        position: relative;
        color: var(--sepia-dark);
    }
    
    .privacy-section ul li::before {
        content: '✓';
        position: absolute;
        left: 0;
        color: var(--accent-green);
        font-weight: 700;
        font-size: 1.2rem;
    }
</style>
