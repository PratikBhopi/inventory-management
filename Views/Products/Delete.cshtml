@model ShopBillingSystem.ViewModels.ProductViewModel

@{
    ViewData["Title"] = "Delete Product";
}

<div class="page-container">
<div class="page-header">
    <h1><i class="fas fa-exclamation-triangle"></i> Delete Product</h1>
    <p class="text-muted">Are you sure you want to delete this product?</p>
</div>

<div class="delete-container">
    <div class="alert alert-danger">
        <i class="fas fa-exclamation-circle"></i>
        <strong>Warning!</strong> This action cannot be undone. The product will be permanently removed from your inventory.
    </div>
    
    <div class="card">
        <div class="card-header">
            <h3><i class="fas fa-box"></i> Product to Delete</h3>
        </div>
        <div class="card-body">
            <div class="product-summary">
                <div class="summary-row">
                    <span class="summary-label">Product Name:</span>
                    <span class="summary-value">@Model.Name</span>
                </div>
                <div class="summary-row">
                    <span class="summary-label">Category:</span>
                    <span class="summary-value">@Model.Category</span>
                </div>
                <div class="summary-row">
                    <span class="summary-label">Description:</span>
                    <span class="summary-value">@(Model.Description ?? "No description")</span>
                </div>
                <div class="summary-row">
                    <span class="summary-label">Price:</span>
                    <span class="summary-value price">$@Model.Price.ToString("F2")</span>
                </div>
                <div class="summary-row">
                    <span class="summary-label">Stock Quantity:</span>
                    <span class="summary-value">@Model.StockQuantity units</span>
                </div>
                <div class="summary-row">
                    <span class="summary-label">Created Date:</span>
                    <span class="summary-value">@Model.CreatedDate.ToString("MMMM dd, yyyy")</span>
                </div>
            </div>
            
            <form asp-action="Delete" method="post" class="delete-form">
                <input type="hidden" asp-for="Id" />
                <div class="form-actions">
                    <button type="submit" class="btn btn-danger btn-lg">
                        <i class="fas fa-trash"></i> Yes, Delete Product
                    </button>
                    <a asp-action="Index" class="btn btn-secondary btn-lg">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
</div>

<style>
    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 var(--space-md);
    }
    
    .page-header {
        margin-bottom: var(--space-xl);
        padding-bottom: var(--space-lg);
        border-bottom: 3px solid var(--accent-red);
    }
    
    .delete-container {
        max-width: 800px;
        margin: 0 auto;
    }
    
    .product-summary {
        background: var(--off-white);
        padding: var(--space-lg);
        border-radius: var(--radius-md);
        margin-bottom: var(--space-lg);
    }
    
    .summary-row {
        display: flex;
        padding: var(--space-sm) 0;
        border-bottom: 1px solid var(--light-grey);
    }
    
    .summary-row:last-child {
        border-bottom: none;
    }
    
    .summary-label {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8125rem;
        letter-spacing: 0.5px;
        color: var(--medium-grey);
        min-width: 150px;
    }
    
    .summary-value {
        color: var(--sepia-dark);
        flex: 1;
    }
    
    .summary-value.price {
        font-family: var(--font-display);
        font-size: 1.25rem;
        color: var(--accent-green);
    }
    
    .form-actions {
        display: flex;
        gap: var(--space-md);
        padding-top: var(--space-lg);
        border-top: 1px solid var(--light-grey);
    }
    
    @@media (max-width: 768px) {
        .form-actions {
            flex-direction: column;
        }
        
        .form-actions .btn {
            width: 100%;
        }
    }
</style>
